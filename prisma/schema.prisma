datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  profiles       Profile[]
  accounts       Account[]
  sessions       Session[]
  sentShares     SharedStory[] @relation("SentShares")
  receivedShares SharedStory[] @relation("ReceivedShares")
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  ageRange  String
  avatar    Json
  createdAt DateTime @default(now())

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories Story[]
}

model Story {
  id        String   @id @default(cuid())
  keywords  Json
  lesson    String
  body      String
  imageUrls Json     @default("[]")
  createdAt DateTime @default(now())

  profileId    String
  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sharedStories SharedStory[]
}

model SharedStory {
  id          String   @id @default(cuid())
  sharedAt    DateTime @default(now())

  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  senderId    String
  sender      User     @relation("SentShares", fields: [senderId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User     @relation("ReceivedShares", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([storyId, recipientId])
}

// NextAuth required models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
